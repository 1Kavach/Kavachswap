{
  "name": "kavach-amm-e2e-tests",
  "version": "1.0.0",
  "description": "Kavach AMM Core — full E2E test suite (devnet/localnet)",
  "scripts": {
    "test":         "mocha kavach_amm_e2e.test.js --timeout 120000 --exit",
    "test:local":   "SOLANA_RPC=http://127.0.0.1:8899 mocha kavach_amm_e2e.test.js --timeout 120000 --exit",
    "test:devnet":  "SOLANA_RPC=https://api.devnet.solana.com mocha kavach_amm_e2e.test.js --timeout 180000 --exit"
  },
  "dependencies": {
    "@solana/web3.js":  "^1.95.8",
    "@solana/spl-token": "^0.4.9",
    "bn.js":            "^5.2.1"
  },
  "devDependencies": {
    "mocha": "^10.7.3",
    "chai":  "^5.1.2"
  }
}
