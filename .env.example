# Solana RPC (required for production builds — copy to .env and set values)
# Vite reads VITE_* variables at build time.

# Cluster: devnet | mainnet-beta | testnet (match your RPC)
VITE_CLUSTER=devnet

# Primary RPC (example: public devnet — replace with your provider URL in production)
VITE_SOLANA_RPC=https://api.devnet.solana.com

# Optional: comma-separated fallback RPC URLs (used if primary fails)
# VITE_SOLANA_RPC_FALLBACKS=https://example-rpc-2.example.com,https://example-rpc-3.example.com

# Router program integration (0 = off, 1 = on) — set per your deployment
VITE_ENABLE_ROUTER=0

# ─── CoinGecko (optional; dashboard / TVL) ─────────────────────────────────
# VITE_COINGECKO_API_KEY=
